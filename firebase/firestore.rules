rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isHouseholdMember(householdId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/households/$(householdId)) &&
        request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberIds;
    }

    match /households/{householdId} {
      allow read, update: if signedIn() && request.auth.uid in resource.data.memberIds;
      allow create: if signedIn() && request.auth.uid in request.resource.data.memberIds;
    }

    match /expenses/{expenseId} {
      allow read, create, update, delete: if isHouseholdMember(resource.data.householdId) || isHouseholdMember(request.resource.data.householdId);
    }

    match /privateExpenseDetails/{detailId} {
      allow read, update, delete: if signedIn() && request.auth.uid == resource.data.ownerId;
      allow create: if signedIn() && request.auth.uid == request.resource.data.ownerId;
    }

    match /{collectionName}/{docId} {
      allow read, create, update, delete: if
        collectionName in [
          'incomes', 'livingTransfers', 'recurringExpenses', 'creditCards',
          'creditCardBills', 'prepaidAccounts', 'prepaidSettlements'
        ] && (isHouseholdMember(resource.data.householdId) || isHouseholdMember(request.resource.data.householdId));
    }
  }
}
