rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function householdDoc(householdId) {
      return /databases/$(database)/documents/households/$(householdId);
    }

    function isHouseholdMember(householdId) {
      return signedIn() &&
        exists(householdDoc(householdId)) &&
        request.auth.uid in get(householdDoc(householdId)).data.memberIds;
    }

    function belongsToHousehold(householdId) {
      return request.resource.data.householdId == householdId;
    }

    function existingBelongsToHousehold(householdId) {
      return resource.data.householdId == householdId;
    }

    match /households/{householdId} {
      allow read, update, delete: if signedIn() && request.auth.uid in resource.data.memberIds;
      allow create: if signedIn() && request.auth.uid in request.resource.data.memberIds;

      match /{collectionName}/{docId} {
        allow read, delete: if collectionName in [
          'expenses',
          'incomes',
          'investments',
          'advances',
          'cardPayments',
          'livingTransfers',
          'recurringExpenses',
          'creditCards',
          'creditCardBills',
          'prepaidAccounts',
          'prepaidSettlements'
        ] && isHouseholdMember(householdId) && existingBelongsToHousehold(householdId);

        allow create: if collectionName in [
          'expenses',
          'incomes',
          'investments',
          'advances',
          'cardPayments',
          'livingTransfers',
          'recurringExpenses',
          'creditCards',
          'creditCardBills',
          'prepaidAccounts',
          'prepaidSettlements'
        ] && isHouseholdMember(householdId) && belongsToHousehold(householdId);

        allow update: if collectionName in [
          'expenses',
          'incomes',
          'investments',
          'advances',
          'cardPayments',
          'livingTransfers',
          'recurringExpenses',
          'creditCards',
          'creditCardBills',
          'prepaidAccounts',
          'prepaidSettlements'
        ] && isHouseholdMember(householdId) && existingBelongsToHousehold(householdId) && belongsToHousehold(householdId);
      }

      match /privateExpenseDetails/{detailId} {
        allow read, delete: if signedIn() && request.auth.uid == resource.data.ownerId;
        allow create: if isHouseholdMember(householdId) &&
          request.auth.uid == request.resource.data.ownerId &&
          request.resource.data.householdId == householdId;
        allow update: if signedIn() &&
          request.auth.uid == resource.data.ownerId &&
          request.resource.data.ownerId == resource.data.ownerId &&
          request.resource.data.householdId == householdId;
      }
    }
  }
}
